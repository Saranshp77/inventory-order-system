# Copy this file to ".env" and adjust values as needed.
# The backend reads DATABASE_URL to decide which database to use.

# --- Local development (default) ---
# If DATABASE_URL is not set at all, the backend falls back to a local
# SQLite file (backend/inventory.db). You do NOT need to set anything to
# run locally. The line below just makes that explicit:
# DATABASE_URL=sqlite:///./inventory.db

# --- Docker / Production (PostgreSQL) ---
# docker-compose sets this automatically. For a manual Postgres run, use:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/inventory

# --- Values used by docker-compose for the postgres service ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory

# --- Backend CORS ---
# Comma-separated list of websites allowed to call the API from a browser.
# Defaults (when unset) to the deployed frontend plus local dev, so you do
# not need to set this in production.
# ALLOWED_ORIGINS=https://inventory-order-system-ruddy.vercel.app,http://localhost:5173

# --- Frontend ---
# Base URL the React app uses to reach the backend API.
VITE_API_URL=http://localhost:8000
